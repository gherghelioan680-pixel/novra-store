# Stripe — plată cu cardul la checkout
# Obține cheile din https://dashboard.stripe.com/apikeys
# Obligatorii (ambele) pentru plată cu cardul:
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# URL public al site-ului (redirect Stripe după plată) — producție:
NEXT_PUBLIC_SITE_URL=https://novra.ro
# Opțional — webhook Stripe pentru confirmare async (recomandat în producție)
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin — DOAR server-side (nu expune în browser)
# Folosit la primul login admin pentru a crea/provisiona contul în users.json
ADMIN_EMAIL=admin@novra.ro
ADMIN_PASSWORD=schimba-parola-in-productie

# Google Analytics 4 — încărcat doar după consimțământ cookie analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Opțional — cron coș abandonat + notificări push (Vercel Cron trimite Authorization: Bearer CRON_SECRET)
# CRON_SECRET=your-random-secret
# ABANDONED_CART_HOURS=2
# ABANDONED_CART_MAX_HOURS=24

# Resend — email confirmare comandă (ramburs + card), tracking AWB, resetare parolă
# Obține cheia din https://resend.com/api-keys
# Obligatoriu pe Vercel pentru emailuri clienți:
RESEND_API_KEY=re_...
# Adresa expeditor — domeniu verificat în Resend (obligatoriu în producție)
RESEND_FROM_EMAIL=NOVRA <comenzi@novra.ro>

# Web Push (PWA) — notificări push admin
# Generează chei VAPID: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:contact@novra.ro

# Vercel KV / Upstash Redis — persistență date store (obligatoriu pe Vercel)
# Creează Redis din Vercel Dashboard → Storage → Marketplace → Upstash Redis
# Vercel setează automat KV_REST_API_URL și KV_REST_API_TOKEN
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your-redis-rest-token
# Alternative Upstash env names (dacă folosești Upstash direct):
# UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token
