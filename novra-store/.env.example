# Stripe — plată cu cardul la checkout
# Obține cheile din https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend — email confirmare comandă și tracking AWB
# Obține cheia din https://resend.com/api-keys
RESEND_API_KEY=re_...
# Adresa expeditor (domeniu verificat în Resend)
RESEND_FROM_EMAIL=NOVRA <comenzi@novra.ro>

# Vercel KV / Upstash Redis — persistență date store (obligatoriu pe Vercel)
# Creează Redis din Vercel Dashboard → Storage → Marketplace → Upstash Redis
# Vercel setează automat KV_REST_API_URL și KV_REST_API_TOKEN
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your-redis-rest-token
# Alternative Upstash env names (dacă folosești Upstash direct):
# UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-rest-token
