{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.novra.ro" }],
      "destination": "https://novra.ro/:path*",
      "statusCode": 308
    }
  ],
  "crons": [
    {
      "path": "/api/cron/abandoned-carts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/push-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/email-campaigns",
      "schedule": "*/5 * * * *"
    }
  ]
}
